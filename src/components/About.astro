---
const bio = "Wide knowledge in the tech industry — mobile development, web development, enterprise software. Fast learner, adaptable to new challenges. Strong command of Java and JavaScript, familiar with numerous frameworks and tools.";

const techStack = [
  { name: "Java", color: "#f89820" },
  { name: "Spring Boot", color: "#6db33f" },
  { name: "JavaScript", color: "#f7df1e" },
  { name: "TypeScript", color: "#3178c6" },
  { name: "Node.js", color: "#339933" },
  { name: "Vue.js", color: "#42b883" },
  { name: "React", color: "#61dafb" },
  { name: "Angular", color: "#dd0031" },
  { name: "Docker", color: "#2496ed" },
  { name: "Kubernetes", color: "#326ce5" },
  { name: "AWS", color: "#ff9900" },
  { name: "MySQL", color: "#4479a1" },
  { name: "Oracle", color: "#f80000" },
  { name: "Git", color: "#f05032" },
  { name: "Android", color: "#3ddc84" },
  { name: "Kafka", color: "#231f20" },
  { name: "RabbitMQ", color: "#ff6600" },
  { name: "Cypress", color: "#17202c" },
];
---

<section id="about" class="relative py-24 sm:py-32">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="reveal mb-16">
      <span class="inline-block px-3 py-1 rounded-full text-xs font-mono uppercase tracking-widest text-[#6366f1] border border-[rgba(99,102,241,0.3)] mb-4">
        About
      </span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold gradient-text mb-6">
        Who I Am
      </h2>
    </div>
    
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20">
      <!-- Bio -->
      <div class="reveal space-y-6">
        <p class="text-lg sm:text-xl text-[#94a3b8] leading-relaxed">
          {bio}
        </p>
        
        <div class="space-y-4 pt-6">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl glass flex items-center justify-center">
              <svg class="w-6 h-6 text-[#6366f1]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
              </svg>
            </div>
            <div>
              <h3 class="text-[#f1f5f9] font-semibold">Software Engineering Degree</h3>
              <p class="text-sm text-[#94a3b8]">Universidad de Málaga, 2010–2014</p>
            </div>
          </div>
          
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl glass flex items-center justify-center">
              <svg class="w-6 h-6 text-[#8b5cf6]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <h3 class="text-[#f1f5f9] font-semibold">Languages</h3>
              <p class="text-sm text-[#94a3b8]">Spanish (Native) · English (B1/B2)</p>
            </div>
          </div>
          
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl glass flex items-center justify-center">
              <svg class="w-6 h-6 text-[#06b6d4]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h3 class="text-[#f1f5f9] font-semibold">Location</h3>
              <p class="text-sm text-[#94a3b8]">Fuengirola, Málaga, Spain</p>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Tech Stack -->
      <div class="reveal" style="transition-delay: 200ms;">
        <h3 class="text-xl font-semibold mb-6 text-[#f1f5f9]">Tech Stack</h3>
        <div class="flex flex-wrap gap-3">
          {techStack.map((tech, index) => (
            <div 
              class="tech-tag inline-flex items-center gap-2 px-4 py-2 rounded-full glass border border-[rgba(255,255,255,0.08)] cursor-default"
              style={`animation: fade-in-up 0.5s ease-out ${index * 50}ms backwards;`}
            >
              <span 
                class="w-2 h-2 rounded-full" 
                style={`background-color: ${tech.color};`}
              ></span>
              <span class="text-sm font-medium text-[#f1f5f9]">{tech.name}</span>
            </div>
          ))}
        </div>
        
        <!-- Stats -->
        <div class="mt-10 grid grid-cols-3 gap-4">
          <div class="glass rounded-2xl p-6 text-center glow-hover transition-all duration-300">
            <div class="text-3xl font-bold gradient-text mb-1">10+</div>
            <div class="text-xs text-[#94a3b8] font-mono uppercase tracking-wider">Years</div>
          </div>
          <div class="glass rounded-2xl p-6 text-center glow-hover transition-all duration-300">
            <div class="text-3xl font-bold gradient-text mb-1">47</div>
            <div class="text-xs text-[#94a3b8] font-mono uppercase tracking-wider">Projects</div>
          </div>
          <div class="glass rounded-2xl p-6 text-center glow-hover transition-all duration-300">
            <div class="text-3xl font-bold gradient-text mb-1">4</div>
            <div class="text-xs text-[#94a3b8] font-mono uppercase tracking-wider">Roles</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
