---

<section id="projects" class="relative py-24 sm:py-32">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="reveal mb-16 text-center">
      <span class="inline-block px-3 py-1 rounded-full text-xs font-mono uppercase tracking-widest text-[#06b6d4] border border-[rgba(6,182,212,0.3)] mb-4">
        Projects
      </span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold gradient-text mb-6">
        Featured Work
      </h2>
      <p class="text-lg text-[#94a3b8] max-w-2xl mx-auto">
        A collection of {projects.length} projects spanning Java, JavaScript, Vue, Android, and more.
      </p>
    </div>
    
    <!-- Filter buttons -->
    <div class="reveal flex flex-wrap justify-center gap-2 mb-12" style="transition-delay: 100ms;">
      {allCategories.map(category => (
        <button 
          class={`filter-btn px-4 py-2 rounded-full text-sm font-medium transition-all duration-300 border ${category === 'All' ? 'active' : ''} border-[rgba(255,255,255,0.08)] text-[#94a3b8] hover:text-[#f1f5f9]`}
          data-filter={category}
        >
          {category}
        </button>
      ))}
    </div>
    
    <!-- Featured Projects Grid -->
    <div class="reveal mb-8" data-category="Featured">
      <h3 class="text-xl font-semibold mb-6 text-[#f1f5f9] flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-[#6366f1]"></span>
        Featured Projects
      </h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {featuredProjects.map((project, index) => (
          <a 
            href={project.url}
            target="_blank"
            rel="noopener noreferrer"
            class={`group block rounded-2xl glass p-6 sm:p-8 glow-hover transition-all duration-300 card-glow ${index === 0 ? 'md:col-span-2' : ''}`}
          >
            <div class="flex items-start justify-between mb-4">
              <div class="flex items-center gap-3">
                <svg class="w-6 h-6 text-[#94a3b8] group-hover:text-[#6366f1] transition-colors" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
                <h4 class="text-lg sm:text-xl font-bold text-[#f1f5f9] group-hover:text-[#6366f1] transition-colors">
                  {project.name}
                </h4>
              </div>
              <span 
                class="px-3 py-1 rounded-full text-xs font-mono"
                style={`background-color: ${languageColors[project.language] || '#94a3b8'}20; color: ${languageColors[project.language] || '#94a3b8'};`}
              >
                {project.language}
              </span>
            </div>
            <p class="text-[#94a3b8] mb-4">{project.description}</p>
            {project.live && (
              <div class="flex items-center gap-2 text-sm text-[#06b6d4]">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
