const featuredProjects = projects.filter(p => p.featured);
const otherProjects = projects.filter(p => !p.featured);
const allCategories = ['All', ...new Set(projects.map(p => p.category))];

const languageColors: Record<string, string> = {
  "Java": "#b07219",
  "TypeScript": "#2b7489",
  "JavaScript": "#f1e05a",
  "Vue": "#41b883",
  "Svelte": "#ff3e00",
  "Kotlin": "#A97BFF",
  "PHP": "#4F5D95",
