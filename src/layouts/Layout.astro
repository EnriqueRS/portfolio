---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Enrique Ríos | Senior Tech Engineer", 
  description = "Portfolio of Enrique Ríos Santos — Senior Tech Engineer. Java, JavaScript & cloud-native architectures."
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#0c0c0c" />
  <title>{title}</title>
</head>
<body>
  <slot />
</body>
</html>
